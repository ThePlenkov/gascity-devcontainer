{
  "name": "AI Development with Gas City",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "./features/gascity": {
      "autoRegister": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "remoteUser": "vscode"
}
