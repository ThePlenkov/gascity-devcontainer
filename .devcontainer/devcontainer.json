{
  "name": "AI Development with Gas City",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "upgradePackages": true
    },
    "./src/gascity": {
      "version": "latest",
      "installDeps": true,
      "installDolt": true
    },
    "./src/devin": {
      "version": "latest"
    },
    "./src/claude": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "postCreateCommand": "echo 'AI development environment ready! Use devin or claude for AI-powered development.'",
  "remoteUser": "vscode"
}
