{
  "id": "gascity",
  "version": "1.0.0",
  "name": "Gas City",
  "description": "Install and validate Gas City - AI agent orchestration platform",
  "documentationURL": "https://github.com/gastownhall/gascity",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "gas-city",
    "devin"
  ],
  "options": {
    "config": {
      "type": "object",
      "description": "Gas City configuration",
      "properties": {
        "autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start supervisor after installation"
        },
        "registerCity": {
          "type": "boolean",
          "default": false,
          "description": "Automatically register city with supervisor"
        },
        "initCity": {
          "type": "boolean",
          "default": false,
          "description": "Initialize city if not exists"
        },
        "configureDolt": {
          "type": "boolean",
          "default": false,
          "description": "Configure Dolt identity for beads storage"
        }
      }
    },
    "buildPack": {
      "type": "object",
      "description": "Gas City build pack configuration",
      "properties": {
        "install": {
          "type": "boolean",
          "default": false,
          "description": "Install gascity build pack from gastownhall/gascity-packs"
        },
        "url": {
          "type": "string",
          "default": "https://github.com/gastownhall/gascity-packs",
          "description": "Build pack repository URL"
        },
        "branch": {
          "type": "string",
          "default": "main",
          "description": "Build pack branch to install"
        }
      }
    }
  },
  "dependsOn": {
    "./features/homebrew": {
      "packages": ["gastownhall/gascity/gascity"]
    }
  },
  "installsAfter": [
    "ghcr.io/devcontainers/features/common-utils"
  ]
}